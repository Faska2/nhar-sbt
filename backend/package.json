{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "cross-env PRISMA_BINARY_CACHE_DIR=./.prisma-cache prisma generate",
    "prisma:migrate": "cross-env PRISMA_BINARY_CACHE_DIR=./.prisma-cache prisma migrate dev --name init",
    "prisma:seed": "cross-env PRISMA_BINARY_CACHE_DIR=./.prisma-cache prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.30",
    "cross-env": "^7.0.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
